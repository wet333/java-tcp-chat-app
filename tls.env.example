# TLS Configuration for TCPChatApp
# Copy this file to tls.env and fill in your values.
# tls.env is gitignored — never commit it.

# ── DEV (localhost, used automatically if no tls.env is found) ──────────────
DEV_TLS_PASSWORD=chatapp_dev_tls
DEV_TLS_VALIDITY=3650

# ── PROD (fill in with your real server data) ───────────────────────────────
# If these are defined, generate_keys.sh will also produce PROD keystores
# and build_project.sh will produce Client_PROD and Server_PROD JARs.
PROD_TLS_CN=chat.midominio.com
PROD_TLS_OU=Backend
PROD_TLS_O=MiEmpresa
PROD_TLS_L=Buenos Aires
PROD_TLS_ST=CABA
PROD_TLS_C=AR
PROD_TLS_PASSWORD=cambiar_esto_en_prod
PROD_TLS_VALIDITY=365
